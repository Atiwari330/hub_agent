{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "crons": [
    {
      "path": "/api/cron/sync-hubspot",
      "schedule": "0 2 * * *"
    },
    {
      "path": "/api/cron/sync-companies",
      "schedule": "30 2 * * *"
    },
    {
      "path": "/api/cron/sentiment-analysis",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/cron/sync-tickets",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/cron/hot-tracker",
      "schedule": "30 3 * * *"
    },
    {
      "path": "/api/cron/demo-tracker",
      "schedule": "0 4 * * *"
    },
    {
      "path": "/api/cron/analyze-support?mode=changed",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/cron/analyze-support?mode=full",
      "schedule": "0 13 * * 1-5"
    },
    {
      "path": "/api/cron/co-destiny-report",
      "schedule": "30 12 * * 1-5"
    },
    {
      "path": "/api/cron/action-item-staleness",
      "schedule": "*/15 * * * *"
    },
    {
      "path": "/api/cron/sla-monitor",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/cron/escalation-sweep",
      "schedule": "*/30 * * * *"
    },
    {
      "path": "/api/cron/pattern-detector",
      "schedule": "0 */2 * * *"
    },
    {
      "path": "/api/cron/stale-checker",
      "schedule": "0 13 * * 1-5"
    }
  ]
}
